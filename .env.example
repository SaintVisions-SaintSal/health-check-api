# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Full connection string â takes precedence over individual fields
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Database Pool Settings
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000

# =============================================================================
# Health Check Settings
# =============================================================================
# TTL in ms for in-memory health check cache (default: 10000)
HEALTH_CACHE_TTL_MS=10000

# Threshold at which memory check reports 'unhealthy' (0-100)
MEMORY_THRESHOLD_PERCENT=90

# =============================================================================
# Rate Limiting
# =============================================================================
# Max requests per windowMs per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# =============================================================================
# App Version (injected at build time by CI or set manually)
# =============================================================================
APP_VERSION=1.0.0
